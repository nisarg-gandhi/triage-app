# Your Groq API Key for AI Ticket Classification
# Get yours at https://console.groq.com/keys
GROQ_API_KEY=gsk_your_groq_api_key_here

# PostgreSQL database URL (e.g., from Supabase)
DATABASE_URL=postgresql://postgres:your_password@db.your_project.supabase.co:5432/postgres

# JWT Secret Key for signing tokens — REQUIRED, no default fallback
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
# Must be a random 64-char hex string (32 bytes). Never commit the real value.
JWT_SECRET_KEY=your_64_char_hex_secret_here

# Optional: Algorithm and Token Expiry
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
